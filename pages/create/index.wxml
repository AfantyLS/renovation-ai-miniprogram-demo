<view class="page">
  <view class="title">创建装修方案</view>
  <view class="subtitle">先填写关键需求。当前 Demo 会用本地逻辑生成一份模拟报告，后续可替换为真实 AI。</view>

  <view class="section card">
    <view class="section-title">户型图</view>
    <view wx:if="{{floorPlanPath}}" class="image-preview">
      <image src="{{floorPlanPath}}" mode="aspectFill"></image>
    </view>
    <button class="ghost-button" bindtap="chooseFloorPlan">{{floorPlanPath ? "重新选择户型图" : "选择户型图"}}</button>
  </view>

  <form bindsubmit="submitForm">
    <view class="section card">
      <view class="field">
        <text class="label">城市</text>
        <input name="city" placeholder="例如：上海" value="{{form.city}}" />
      </view>

      <view class="field">
        <text class="label">建筑面积</text>
        <input name="area" type="number" placeholder="例如：98" value="{{form.area}}" />
      </view>

      <view class="field">
        <text class="label">户型</text>
        <input name="layout" placeholder="例如：三室两厅一卫" value="{{form.layout}}" />
      </view>

      <view class="field">
        <text class="label">预算范围</text>
        <picker name="budget" range="{{budgetOptions}}" value="{{budgetIndex}}" bindchange="onBudgetChange">
          <view class="picker-value">{{budgetOptions[budgetIndex]}}</view>
        </picker>
      </view>

      <view class="field">
        <text class="label">装修风格</text>
        <picker name="style" range="{{styleOptions}}" value="{{styleIndex}}" bindchange="onStyleChange">
          <view class="picker-value">{{styleOptions[styleIndex]}}</view>
        </picker>
      </view>

      <view class="field">
        <text class="label">家庭结构</text>
        <input name="family" placeholder="例如：夫妻二人 + 一个孩子" value="{{form.family}}" />
      </view>

      <view class="field">
        <text class="label">重点需求</text>
        <textarea name="needs" placeholder="例如：多收纳、儿童友好、好打理、需要书房" value="{{form.needs}}" />
      </view>
    </view>

    <button class="primary-button" form-type="submit">生成 Demo 报告</button>
  </form>
</view>

