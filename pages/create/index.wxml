<view class="page">
  <view class="create-top">
    <view class="title">整一套</view>
    <view class="subtitle">上传户型图，再把你的想法丢进 Prompt。其余交给方案生成器。</view>
  </view>

  <view class="section upload-card">
    <view wx:if="{{floorPlanPath}}" class="image-preview">
      <image src="{{floorPlanPath}}" mode="aspectFill"></image>
    </view>
    <view wx:else class="upload-empty">
      <view class="upload-title">上传户型图</view>
      <view class="upload-text">支持从相册选择或拍照</view>
    </view>
    <button class="ghost-button" bindtap="chooseFloorPlan">{{floorPlanPath ? "重新选择" : "选择图片"}}</button>
  </view>

  <view class="section prompt-card">
    <view class="prompt-label">Prompt</view>
    <textarea
      class="prompt-input"
      placeholder="例如：90平三室两厅，原木风，预算20万，希望多收纳、儿童友好、厨房好清洁。"
      value="{{promptValue}}"
      maxlength="500"
      bindinput="onPromptInput"
    ></textarea>

    <view class="template-title">快速套用</view>
    <view class="template-list">
      <view
        wx:for="{{promptTemplates}}"
        wx:key="*this"
        class="template-chip"
        data-index="{{index}}"
        bindtap="useTemplate"
      >{{item}}</view>
    </view>
  </view>

  <button class="primary-button generate-button" bindtap="generateReport">生成方案</button>
</view>
