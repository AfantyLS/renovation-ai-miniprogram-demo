<view class="page">
  <view class="title">创建方案</view>
  <view class="subtitle">只填几个关键信息，先生成一版可看的装修建议。</view>

  <view class="section upload-card">
    <view wx:if="{{floorPlanPath}}" class="image-preview">
      <image src="{{floorPlanPath}}" mode="aspectFill"></image>
    </view>
    <view wx:else class="upload-empty">
      <view class="upload-title">上传户型图</view>
      <view class="upload-text">支持从相册选择或拍照</view>
    </view>
    <button class="ghost-button" bindtap="chooseFloorPlan">{{floorPlanPath ? "重新选择" : "选择图片"}}</button>
  </view>

  <form bindsubmit="submitForm">
    <view class="section card">
      <view class="field">
        <text class="label">建筑面积</text>
        <input name="area" type="number" placeholder="例如：98" value="{{form.area}}" />
      </view>

      <view class="field">
        <text class="label">预算范围</text>
        <picker name="budget" range="{{budgetOptions}}" value="{{budgetIndex}}" bindchange="onBudgetChange">
          <view class="picker-value">{{budgetOptions[budgetIndex]}}</view>
        </picker>
      </view>

      <view class="field">
        <text class="label">装修风格</text>
        <picker name="style" range="{{styleOptions}}" value="{{styleIndex}}" bindchange="onStyleChange">
          <view class="picker-value">{{styleOptions[styleIndex]}}</view>
        </picker>
      </view>

      <view class="field">
        <text class="label">一句话需求</text>
        <textarea name="needs" placeholder="例如：想要更多收纳，整体温馨好打理" value="{{form.needs}}" />
      </view>
    </view>

    <button class="primary-button" form-type="submit">生成方案</button>
  </form>
</view>
