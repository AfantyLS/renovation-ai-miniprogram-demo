.create-top {
  padding: 14rpx 6rpx 4rpx;
}

.upload-card {
  overflow: hidden;
  padding: 0;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 46rpx rgba(36, 31, 26, 0.08);
}

.upload-empty {
  height: 300rpx;
  padding: 46rpx 34rpx;
  box-sizing: border-box;
  background: linear-gradient(140deg, #ecf1ed 0%, #fff7ea 100%);
}

.upload-title {
  color: #241f1a;
  font-size: 34rpx;
  font-weight: 800;
}

.upload-text {
  margin-top: 14rpx;
  color: #81786d;
  font-size: 26rpx;
}

.image-preview {
  width: 100%;
  height: 340rpx;
  overflow: hidden;
  background: #eef2f1;
}

.image-preview image {
  width: 100%;
  height: 100%;
}

.upload-card .ghost-button {
  margin: 22rpx;
}

.prompt-card {
  padding: 30rpx;
  border-radius: 32rpx;
  background: #fffdf8;
  box-shadow: 0 18rpx 46rpx rgba(36, 31, 26, 0.08);
}

.prompt-label {
  color: #241f1a;
  font-size: 30rpx;
  font-weight: 900;
}

.prompt-input {
  width: 100%;
  min-height: 260rpx;
  margin-top: 22rpx;
  padding: 26rpx;
  box-sizing: border-box;
  border-radius: 26rpx;
  background: #f6f2ea;
  color: #241f1a;
  font-size: 29rpx;
  line-height: 1.55;
}

.template-title {
  margin-top: 28rpx;
  color: #9c6a45;
  font-size: 24rpx;
  font-weight: 900;
}

.template-list {
  margin-top: 14rpx;
}

.template-chip {
  margin-top: 14rpx;
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: #f0e9df;
  color: #4d4338;
  font-size: 25rpx;
  line-height: 1.45;
}

.generate-button {
  margin-top: 32rpx;
}
