.field {
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(38, 50, 56, 0.08);
}

.field:last-child {
  border-bottom: 0;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  color: #263238;
  font-size: 26rpx;
  font-weight: 700;
}

input,
textarea,
.picker-value {
  width: 100%;
  min-height: 72rpx;
  box-sizing: border-box;
  color: #263238;
  font-size: 28rpx;
}

textarea {
  min-height: 150rpx;
}

.image-preview {
  margin-top: 20rpx;
  width: 100%;
  height: 340rpx;
  overflow: hidden;
  border-radius: 14rpx;
  background: #eef2f1;
}

.image-preview image {
  width: 100%;
  height: 100%;
}

