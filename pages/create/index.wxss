.page {
  padding: 22rpx 24rpx 32rpx;
}

.create-top {
  padding: 4rpx 4rpx 0;
}

.create-top .title {
  font-size: 42rpx;
}

.create-top .subtitle {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.45;
}

.upload-card {
  display: flex;
  align-items: center;
  overflow: hidden;
  min-height: 154rpx;
  margin-top: 18rpx;
  padding: 16rpx;
  box-sizing: border-box;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 46rpx rgba(36, 31, 26, 0.08);
}

.upload-empty {
  flex: 1;
  height: 120rpx;
  padding: 20rpx 22rpx;
  box-sizing: border-box;
  border-radius: 22rpx;
  background: linear-gradient(140deg, #ecf1ed 0%, #fff7ea 100%);
}

.upload-title {
  color: #241f1a;
  font-size: 30rpx;
  font-weight: 800;
}

.upload-text {
  margin-top: 8rpx;
  color: #81786d;
  font-size: 23rpx;
}

.image-preview {
  flex: 1;
  height: 120rpx;
  overflow: hidden;
  border-radius: 22rpx;
  background: #eef2f1;
}

.image-preview image {
  width: 100%;
  height: 100%;
}

.upload-card .ghost-button {
  flex: none;
  width: 156rpx;
  height: 70rpx;
  margin: 0 0 0 16rpx;
  font-size: 25rpx;
}

.prompt-card {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 28rpx;
  background: #fffdf8;
  box-shadow: 0 18rpx 46rpx rgba(36, 31, 26, 0.08);
}

.prompt-label {
  color: #241f1a;
  font-size: 28rpx;
  font-weight: 900;
}

.prompt-input {
  width: 100%;
  min-height: 190rpx;
  margin-top: 16rpx;
  padding: 22rpx;
  box-sizing: border-box;
  border-radius: 22rpx;
  background: #f6f2ea;
  color: #241f1a;
  font-size: 27rpx;
  line-height: 1.5;
}

.template-title {
  margin-top: 18rpx;
  color: #9c6a45;
  font-size: 23rpx;
  font-weight: 900;
}

.template-list {
  width: 100%;
  margin-top: 12rpx;
  white-space: nowrap;
}

.template-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: #f0e9df;
  color: #4d4338;
  font-size: 24rpx;
  line-height: 1;
}

.generate-button {
  margin-top: 22rpx;
  height: 88rpx;
}
