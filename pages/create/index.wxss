.field {
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(32, 38, 36, 0.08);
}

.field:last-child {
  border-bottom: 0;
}

.label {
  display: block;
  margin-bottom: 16rpx;
  color: #202624;
  font-size: 26rpx;
  font-weight: 800;
}

input,
textarea,
.picker-value {
  width: 100%;
  min-height: 78rpx;
  box-sizing: border-box;
  color: #202624;
  font-size: 28rpx;
}

textarea {
  min-height: 132rpx;
}

.upload-card {
  overflow: hidden;
  padding: 0;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 46rpx rgba(32, 38, 36, 0.07);
}

.upload-empty {
  height: 300rpx;
  padding: 46rpx 34rpx;
  box-sizing: border-box;
  background: linear-gradient(140deg, #eff5f1 0%, #fff8ef 100%);
}

.upload-title {
  color: #202624;
  font-size: 34rpx;
  font-weight: 800;
}

.upload-text {
  margin-top: 14rpx;
  color: #74807a;
  font-size: 26rpx;
}

.image-preview {
  width: 100%;
  height: 340rpx;
  overflow: hidden;
  background: #eef2f1;
}

.image-preview image {
  width: 100%;
  height: 100%;
}

.upload-card .ghost-button {
  margin: 22rpx;
}
