.hero {
  padding: 8rpx 0 16rpx;
}

.hero-card {
  position: relative;
  overflow: hidden;
  min-height: 560rpx;
  padding: 48rpx 38rpx;
  box-sizing: border-box;
  border-radius: 36rpx;
  background: linear-gradient(145deg, #fff8ef 0%, #e9f2ec 54%, #d8e6e1 100%);
  box-shadow: 0 24rpx 60rpx rgba(33, 77, 67, 0.12);
}

.hero-card::after {
  content: "";
  position: absolute;
  right: -120rpx;
  bottom: -90rpx;
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.45);
}

.eyebrow {
  position: relative;
  z-index: 1;
  margin-bottom: 26rpx;
  color: #9a6236;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.hero .title,
.hero .subtitle,
.hero .primary-button {
  position: relative;
  z-index: 1;
}

.quick-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.quick-card {
  width: calc(50% - 10rpx);
  min-height: 180rpx;
  margin-bottom: 20rpx;
  padding: 28rpx;
  box-sizing: border-box;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 40rpx rgba(32, 38, 36, 0.06);
}

.quick-card.wide {
  width: 100%;
  min-height: 150rpx;
}

.quick-number {
  color: #b26c40;
  font-size: 24rpx;
  font-weight: 800;
}

.quick-title {
  margin-top: 18rpx;
  color: #202624;
  font-size: 30rpx;
  font-weight: 800;
}

.quick-text {
  margin-top: 10rpx;
  color: #74807a;
  font-size: 25rpx;
  line-height: 1.45;
}
