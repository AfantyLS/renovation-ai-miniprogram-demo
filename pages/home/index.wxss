.home-page {
  min-height: 100vh;
  padding: 28rpx 28rpx 52rpx;
  box-sizing: border-box;
  background: #f6f2ea;
}

.hero {
  position: relative;
  overflow: hidden;
  height: 760rpx;
  border-radius: 42rpx;
  box-shadow: 0 28rpx 70rpx rgba(36, 31, 26, 0.16);
}

.hero-image {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
}

.hero-shade {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(18, 16, 13, 0.08) 0%, rgba(18, 16, 13, 0.24) 48%, rgba(18, 16, 13, 0.78) 100%);
}

.hero-content {
  position: absolute;
  left: 34rpx;
  right: 34rpx;
  bottom: 34rpx;
}

.eyebrow {
  display: inline-block;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #fff8ec;
  font-size: 24rpx;
  font-weight: 800;
  letter-spacing: 0;
  backdrop-filter: blur(12rpx);
}

.hero-title {
  margin-top: 24rpx;
  color: #fffdf7;
  font-size: 60rpx;
  line-height: 1.08;
  font-weight: 900;
  letter-spacing: 0;
}

.hero-subtitle {
  margin-top: 20rpx;
  color: rgba(255, 253, 247, 0.86);
  font-size: 28rpx;
  line-height: 1.55;
}

.hero-actions {
  display: flex;
  align-items: center;
  margin-top: 30rpx;
}

.hero-primary,
.hero-secondary {
  margin: 0;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.hero-primary {
  width: 260rpx;
  background: #fff7e9;
  color: #241f1a;
}

.hero-secondary {
  width: 220rpx;
  margin-left: 18rpx;
  background: rgba(255, 255, 255, 0.16);
  color: #fff7e9;
  border: 1rpx solid rgba(255, 255, 255, 0.24);
}

.section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 42rpx;
}

.section-kicker {
  color: #9c6a45;
  font-size: 24rpx;
  font-weight: 800;
}

.section-heading {
  margin-top: 8rpx;
  color: #241f1a;
  font-size: 38rpx;
  font-weight: 800;
}

.section-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background: #1f493f;
  box-shadow: 0 0 0 14rpx rgba(31, 73, 63, 0.09);
}

.feature-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-top: 24rpx;
}

.feature-card {
  width: 48%;
  min-height: 220rpx;
  margin-bottom: 20rpx;
  padding: 28rpx;
  box-sizing: border-box;
  border-radius: 32rpx;
  background: #fffdf8;
  box-shadow: 0 16rpx 44rpx rgba(36, 31, 26, 0.08);
}

.feature-card.dark {
  background: #1f493f;
}

.feature-card.warm {
  background: #df8d55;
}

.feature-title {
  color: #241f1a;
  font-size: 30rpx;
  line-height: 1.25;
  font-weight: 900;
}

.feature-text {
  margin-top: 16rpx;
  color: #7b7165;
  font-size: 25rpx;
  line-height: 1.5;
}

.feature-card.dark .feature-title,
.feature-card.dark .feature-text,
.feature-card.warm .feature-title,
.feature-card.warm .feature-text {
  color: #fff8ec;
}
