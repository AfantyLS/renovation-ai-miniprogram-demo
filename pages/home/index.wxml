<view class="page">
  <view class="hero">
    <view class="hero-card">
      <view class="eyebrow">AI Interior Planner</view>
      <view class="title">把户型图变成装修方案</view>
      <view class="subtitle">上传户型图，选择预算和风格，快速生成一份可阅读的空间规划报告。</view>
      <button class="primary-button" bindtap="goCreate">开始生成</button>
    </view>
  </view>

  <view class="section quick-grid">
    <view class="quick-card">
      <view class="quick-number">01</view>
      <view class="quick-title">上传户型</view>
      <view class="quick-text">选择图片即可开始</view>
    </view>
    <view class="quick-card">
      <view class="quick-number">02</view>
      <view class="quick-title">选择偏好</view>
      <view class="quick-text">预算、风格和需求</view>
    </view>
    <view class="quick-card wide">
      <view class="quick-number">03</view>
      <view class="quick-title">生成报告</view>
      <view class="quick-text">包含空间建议、材料清单和预算估算</view>
    </view>
  </view>
</view>
