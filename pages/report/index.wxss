.report-page {
  min-height: 100vh;
  padding: 22rpx 20rpx 52rpx;
  box-sizing: border-box;
  background: #ebe3d6;
}

.report-document {
  overflow: hidden;
  border-radius: 34rpx;
  background: #fffdf8;
  box-shadow: 0 24rpx 70rpx rgba(36, 31, 26, 0.14);
}

.cover {
  position: relative;
  height: 360rpx;
  overflow: hidden;
}

.cover-image {
  position: absolute;
  width: 100%;
  height: 100%;
}

.cover-shade {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(20, 17, 14, 0.18) 0%, rgba(20, 17, 14, 0.72) 100%);
}

.cover-copy {
  position: absolute;
  left: 34rpx;
  right: 34rpx;
  bottom: 30rpx;
}

.cover-kicker {
  color: rgba(255, 248, 236, 0.8);
  font-size: 23rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.cover-title {
  margin-top: 12rpx;
  color: #fffdf8;
  font-size: 46rpx;
  line-height: 1.15;
  font-weight: 900;
}

.cover-meta {
  margin-top: 12rpx;
  color: rgba(255, 248, 236, 0.88);
  font-size: 28rpx;
  font-weight: 700;
}

.html-section {
  padding: 38rpx 34rpx;
  border-bottom: 1rpx solid rgba(36, 31, 26, 0.08);
}

.html-section:last-child {
  border-bottom: 0;
}

.html-label {
  color: #9c6a45;
  font-size: 22rpx;
  font-weight: 900;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.section-index {
  color: rgba(156, 106, 69, 0.18);
  font-size: 58rpx;
  line-height: 1;
  font-weight: 900;
}

.summary {
  margin-top: 22rpx;
  color: #3f372e;
  font-size: 29rpx;
  line-height: 1.75;
}

.analysis-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-top: 24rpx;
}

.analysis-card {
  width: 100%;
  margin-top: 16rpx;
  padding: 22rpx;
  box-sizing: border-box;
  border-radius: 22rpx;
  background: #f6f2ea;
}

.analysis-title {
  color: #1f493f;
  font-size: 28rpx;
  font-weight: 900;
}

.analysis-copy {
  margin-top: 10rpx;
  color: #5e554b;
  font-size: 26rpx;
  line-height: 1.55;
}

.html-title {
  color: #241f1a;
  font-size: 38rpx;
  line-height: 1.25;
  font-weight: 900;
}

.render-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-top: 24rpx;
}

.render-card {
  position: relative;
  overflow: hidden;
  width: 48%;
  height: 240rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
  box-sizing: border-box;
  border-radius: 28rpx;
  background: linear-gradient(145deg, #d9c6aa 0%, #8f9b7c 100%);
  color: #fffdf8;
}

.render-card:active .render-image {
  transform: scale(1.04);
}

.render-image {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
  transition: transform 180ms ease;
}

.render-shade {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(20, 17, 14, 0.06) 0%, rgba(20, 17, 14, 0.7) 100%);
}

.render-zoom {
  position: absolute;
  right: 18rpx;
  top: 18rpx;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  background: rgba(255, 253, 248, 0.22);
  box-shadow: 0 0 0 0 rgba(255, 253, 248, 0.32);
  animation: zoomPulse 1.8s ease-in-out infinite;
  backdrop-filter: blur(12rpx);
}

.zoom-mark {
  position: relative;
  width: 20rpx;
  height: 20rpx;
  border: 4rpx solid #fffdf8;
  border-radius: 50%;
  box-sizing: border-box;
}

.zoom-mark::after {
  content: "";
  position: absolute;
  right: -11rpx;
  bottom: -7rpx;
  width: 14rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #fffdf8;
  transform: rotate(45deg);
}

@keyframes zoomPulse {
  0% {
    transform: scale(1);
    box-shadow: 0 0 0 0 rgba(255, 253, 248, 0.28);
  }

  58% {
    transform: scale(1.06);
    box-shadow: 0 0 0 14rpx rgba(255, 253, 248, 0);
  }

  100% {
    transform: scale(1);
    box-shadow: 0 0 0 0 rgba(255, 253, 248, 0);
  }
}

.render-card.bedroom {
  background: linear-gradient(145deg, #e8d9c5 0%, #a8755c 100%);
}

.render-card.kitchen {
  background: linear-gradient(145deg, #c7d2c7 0%, #53685c 100%);
}

.render-card.bath {
  background: linear-gradient(145deg, #d8ddd8 0%, #7f8c8b 100%);
}

.render-room {
  position: relative;
  z-index: 1;
  font-size: 24rpx;
  font-weight: 900;
  opacity: 0.86;
}

.render-title {
  position: relative;
  z-index: 1;
  margin-top: 76rpx;
  font-size: 30rpx;
  line-height: 1.25;
  font-weight: 900;
}

.idea-item {
  display: flex;
  margin-top: 24rpx;
}

.idea-dot {
  flex: none;
  width: 14rpx;
  height: 14rpx;
  margin-top: 13rpx;
  border-radius: 50%;
  background: #1f493f;
}

.idea-text {
  margin-left: 18rpx;
  color: #4d4338;
  font-size: 28rpx;
  line-height: 1.6;
}

.room-article {
  margin-top: 28rpx;
  padding-top: 26rpx;
  border-top: 1rpx solid rgba(36, 31, 26, 0.08);
}

.room-heading {
  color: #9c6a45;
  font-size: 28rpx;
  font-weight: 900;
}

.room-copy {
  margin-top: 14rpx;
  color: #3f372e;
  font-size: 28rpx;
  line-height: 1.7;
}

.room-note {
  margin-top: 14rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #f6f2ea;
  color: #756d62;
  font-size: 25rpx;
  line-height: 1.55;
}

.report-table {
  margin-top: 22rpx;
  overflow: hidden;
  border-radius: 22rpx;
  border: 1rpx solid rgba(36, 31, 26, 0.08);
}

.table-row {
  display: flex;
  justify-content: space-between;
  padding: 22rpx;
  border-bottom: 1rpx solid rgba(36, 31, 26, 0.08);
  color: #4d4338;
  font-size: 26rpx;
}

.table-row:last-child {
  border-bottom: 0;
}

.table-row text {
  width: 48%;
}

.table-row text:last-child {
  text-align: right;
  color: #81786d;
}

.table-head {
  background: #f0e9df;
  color: #241f1a;
  font-weight: 900;
}

.budget-total {
  margin-top: 22rpx;
  color: #1f493f;
  font-size: 54rpx;
  line-height: 1.1;
  font-weight: 900;
}

.budget-line {
  display: flex;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(36, 31, 26, 0.08);
  color: #4d4338;
  font-size: 27rpx;
}

.budget-line:last-child {
  border-bottom: 0;
}

.budget-amount {
  font-weight: 900;
}

.next-item {
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: #f6f2ea;
  color: #4d4338;
  font-size: 27rpx;
  line-height: 1.5;
}

.report-actions {
  display: flex;
  justify-content: space-between;
  margin-top: 26rpx;
}

.action-button {
  width: 48%;
  margin-top: 0;
}

.empty {
  padding-top: 160rpx;
}
