<view class="page" wx:if="{{report}}">
  <view class="report-header">
    <view class="title">{{report.project.style}}装修方案</view>
    <view class="subtitle">{{report.project.area}}㎡ · {{report.project.layout}}</view>
    <view class="tag">{{report.project.budget}}</view>
  </view>

  <view class="section card">
    <view class="section-title">整体总结</view>
    <view class="paragraph">{{report.summary}}</view>
  </view>

  <view class="section card">
    <view class="section-title">方案亮点</view>
    <view wx:for="{{report.highlights}}" wx:key="*this" class="list-item">{{item}}</view>
  </view>

  <view class="section card">
    <view class="section-title">房间方案</view>
    <view wx:for="{{report.rooms}}" wx:key="name" class="room-block">
      <view class="room-name">{{item.name}}</view>
      <view class="paragraph">{{item.plan}}</view>
      <view class="note">{{item.materials}}</view>
    </view>
  </view>

  <view class="section card">
    <view class="section-title">材料建议</view>
    <view wx:for="{{report.materials}}" wx:key="name" class="compact-item">
      <view class="compact-main">{{item.name}}</view>
      <view class="compact-sub">{{item.room}} · {{item.note}}</view>
    </view>
  </view>

  <view class="section card">
    <view class="section-title">家具家电建议</view>
    <view wx:for="{{report.furniture}}" wx:key="name" class="compact-item">
      <view class="compact-main">{{item.name}}</view>
      <view class="compact-sub">{{item.room}} · {{item.note}}</view>
    </view>
  </view>

  <view class="section card">
    <view class="section-title">预算估算</view>
    <view class="budget-total">约 {{report.budget.total}} 元</view>
    <view wx:for="{{report.budget.items}}" wx:key="name" class="budget-row">
      <text>{{item.name}}</text>
      <text>{{item.amount}} 元</text>
    </view>
  </view>

  <view class="section card">
    <view class="section-title">下一步任务</view>
    <view wx:for="{{report.nextSteps}}" wx:key="*this" class="list-item">{{item}}</view>
  </view>

  <button class="primary-button" bindtap="goCreate">再生成一份</button>
</view>

<view class="page empty" wx:else>
  <view class="title">还没有报告</view>
  <view class="subtitle">先创建一个装修方案，再查看报告。</view>
  <button class="primary-button" bindtap="goCreate">去创建</button>
</view>
