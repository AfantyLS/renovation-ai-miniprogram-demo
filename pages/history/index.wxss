.history-head {
  padding: 14rpx 6rpx 8rpx;
}

.report-list {
  margin-top: 24rpx;
}

.history-card {
  position: relative;
  display: flex;
  overflow: hidden;
  min-height: 220rpx;
  margin-bottom: 22rpx;
  padding: 26rpx;
  box-sizing: border-box;
  border-radius: 30rpx;
  box-shadow: 0 18rpx 46rpx rgba(36, 31, 26, 0.08);
}

.history-bg {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
}

.history-mask {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: linear-gradient(90deg, rgba(20, 17, 14, 0.78) 0%, rgba(20, 17, 14, 0.44) 58%, rgba(20, 17, 14, 0.18) 100%);
}

.history-body {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
  padding: 0;
}

.history-title {
  color: #fffdf8;
  font-size: 34rpx;
  line-height: 1.25;
  font-weight: 900;
}

.history-sub {
  margin-top: 10rpx;
  color: rgba(255, 248, 236, 0.78);
  font-size: 24rpx;
}

.history-summary {
  display: -webkit-box;
  overflow: hidden;
  max-width: 470rpx;
  margin-top: 18rpx;
  color: rgba(255, 248, 236, 0.88);
  font-size: 25rpx;
  line-height: 1.45;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.empty-card {
  margin-top: 60rpx;
  padding: 42rpx;
  border-radius: 34rpx;
  background: #fffdf8;
  box-shadow: 0 18rpx 46rpx rgba(36, 31, 26, 0.08);
}

.empty-title {
  color: #241f1a;
  font-size: 38rpx;
  font-weight: 900;
}

.empty-text {
  margin-top: 18rpx;
  color: #756d62;
  font-size: 28rpx;
  line-height: 1.55;
}
