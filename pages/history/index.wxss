.history-head {
  padding: 14rpx 6rpx 8rpx;
}

.report-list {
  margin-top: 24rpx;
}

.history-card {
  display: flex;
  margin-bottom: 22rpx;
  padding: 18rpx;
  border-radius: 30rpx;
  background: #fffdf8;
  box-shadow: 0 18rpx 46rpx rgba(36, 31, 26, 0.08);
}

.history-cover {
  flex: none;
  width: 180rpx;
  height: 180rpx;
  overflow: hidden;
  border-radius: 24rpx;
  background: #efe7db;
}

.history-cover image {
  width: 100%;
  height: 100%;
}

.history-body {
  flex: 1;
  min-width: 0;
  padding: 8rpx 0 0 22rpx;
}

.history-title {
  color: #241f1a;
  font-size: 30rpx;
  line-height: 1.25;
  font-weight: 900;
}

.history-sub {
  margin-top: 10rpx;
  color: #9c6a45;
  font-size: 24rpx;
}

.history-prompt {
  display: -webkit-box;
  overflow: hidden;
  margin-top: 14rpx;
  color: #756d62;
  font-size: 25rpx;
  line-height: 1.45;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.empty-card {
  margin-top: 60rpx;
  padding: 42rpx;
  border-radius: 34rpx;
  background: #fffdf8;
  box-shadow: 0 18rpx 46rpx rgba(36, 31, 26, 0.08);
}

.empty-title {
  color: #241f1a;
  font-size: 38rpx;
  font-weight: 900;
}

.empty-text {
  margin-top: 18rpx;
  color: #756d62;
  font-size: 28rpx;
  line-height: 1.55;
}

