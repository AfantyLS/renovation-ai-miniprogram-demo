page {
  min-height: 100%;
  background: #f6f7f4;
  color: #202624;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

.page {
  min-height: 100vh;
  padding: 36rpx 32rpx 48rpx;
  box-sizing: border-box;
}

.section {
  margin-top: 24rpx;
}

.card {
  background: #ffffff;
  border: 1rpx solid rgba(32, 38, 36, 0.07);
  border-radius: 28rpx;
  padding: 30rpx;
  box-shadow: 0 18rpx 46rpx rgba(32, 38, 36, 0.07);
}

.title {
  font-size: 48rpx;
  line-height: 1.2;
  font-weight: 800;
  letter-spacing: 0;
}

.subtitle {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #66706b;
}

.section-title {
  font-size: 31rpx;
  line-height: 1.35;
  font-weight: 800;
}

.muted {
  color: #74807a;
}

.primary-button {
  margin-top: 32rpx;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 22rpx;
  background: #214d43;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 18rpx 34rpx rgba(33, 77, 67, 0.2);
}

button::after {
  border: 0;
}

.ghost-button {
  margin-top: 20rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 20rpx;
  background: #edf3ef;
  color: #214d43;
  border: 0;
  font-size: 28rpx;
}

.tag {
  display: inline-block;
  margin: 12rpx 12rpx 0 0;
  padding: 9rpx 18rpx;
  border-radius: 999rpx;
  background: #eaf1ee;
  color: #214d43;
  font-size: 24rpx;
}
