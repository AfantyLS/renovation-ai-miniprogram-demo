page {
  min-height: 100%;
  background: #f7f3ee;
  color: #263238;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.section {
  margin-top: 28rpx;
}

.card {
  background: #ffffff;
  border: 1rpx solid rgba(38, 50, 56, 0.08);
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(38, 50, 56, 0.06);
}

.title {
  font-size: 44rpx;
  line-height: 1.2;
  font-weight: 700;
}

.subtitle {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #5d666b;
}

.section-title {
  font-size: 32rpx;
  line-height: 1.35;
  font-weight: 700;
}

.muted {
  color: #6f7a80;
}

.primary-button {
  margin-top: 32rpx;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 14rpx;
  background: #2f6f68;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
}

.ghost-button {
  margin-top: 20rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 14rpx;
  background: #ffffff;
  color: #2f6f68;
  border: 1rpx solid rgba(47, 111, 104, 0.24);
  font-size: 28rpx;
}

.tag {
  display: inline-block;
  margin: 12rpx 12rpx 0 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #e9f1ef;
  color: #2f6f68;
  font-size: 24rpx;
}

